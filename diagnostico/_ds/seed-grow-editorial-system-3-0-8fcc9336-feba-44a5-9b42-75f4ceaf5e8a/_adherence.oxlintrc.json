{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/layouts/**",
              "components/post-layouts/**",
              "components/post/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Archivo))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Archivo."
      },
      {
        "selector": "JSXOpeningElement[name.name='L001EditorialCover'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|headline|highlight|headlineEnd|atmosphere|imageLabel|key|ref|className|style|children)$/]",
        "message": "<L001EditorialCover> doesn't accept that prop. Declared props: kicker, headline, highlight, headlineEnd, atmosphere, imageLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='L001EditorialCover'] > JSXAttribute[name.name='atmosphere'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<L001EditorialCover> atmosphere must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='L002EditorialStory'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|headline|body|accent|atmosphere|imageLabel|key|ref|className|style|children)$/]",
        "message": "<L002EditorialStory> doesn't accept that prop. Declared props: kicker, headline, body, accent, atmosphere, imageLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='L002EditorialStory'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:yellow-green|cayenne)$/]",
        "message": "<L002EditorialStory> accent must be one of 'yellow-green' | 'cayenne'."
      },
      {
        "selector": "JSXOpeningElement[name.name='L002EditorialStory'] > JSXAttribute[name.name='atmosphere'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<L002EditorialStory> atmosphere must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='L003HeroStatistic'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|stat|suffix|headline|support|quote|quoteSource|atmosphere|key|ref|className|style|children)$/]",
        "message": "<L003HeroStatistic> doesn't accept that prop. Declared props: kicker, stat, suffix, headline, support, quote, quoteSource, atmosphere."
      },
      {
        "selector": "JSXOpeningElement[name.name='L003HeroStatistic'] > JSXAttribute[name.name='atmosphere'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<L003HeroStatistic> atmosphere must be one of 'light' | 'dark'."
